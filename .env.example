# ─────────────────────────────────────────────────────────────
# Payload CMS (Phase 2 — Blog/Admin). Bắt buộc để chạy /admin & blog.
# Copy file này thành .env.local rồi điền giá trị thật.
# ─────────────────────────────────────────────────────────────

# Postgres (Neon) — chuỗi kết nối, lấy từ dashboard Neon.
# Ví dụ: postgresql://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/dbname?sslmode=require
DATABASE_URI=

# Secret ngẫu nhiên cho Payload (auth/JWT). Tạo bằng: openssl rand -base64 32
PAYLOAD_SECRET=

# Vercel Blob — token đọc/ghi để lưu ảnh upload. Lấy trong Vercel → Storage → Blob.
BLOB_READ_WRITE_TOKEN=

# ─────────────────────────────────────────────────────────────
# EmailJS (tuỳ chọn — đã có default trong src/lib/emailjs.ts, chỉ điền nếu đổi tài khoản)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# ─────────────────────────────────────────────────────────────
# Tuỳ chọn: override domain gốc cho metadata/OG (mặc định lấy từ src/data/site.ts)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=
